{
  "name": "@eurobuddha/mini-merch",
  "version": "0.2.0",
  "description": "CLI tool to generate miniMerch MiniDapps for the Minima blockchain — sell physical or digital goods with built-in encrypted messaging",
  "main": "src/index.js",
  "bin": {
    "mini-merch": "./src/index.js"
  },
  "scripts": {
    "studio": "node src/studio.js",
    "build:mac": "bash build/build-mac.sh",
    "build:win": "bash build/build-win.sh",
    "build": "npm run build:mac \u0026\u0026 npm run build:win",
    "lint": "eslint src/ template/shop/*.js template/inbox/*.js --ext .js || true",
    "lint:fix": "eslint src/ template/shop/*.js template/inbox/*.js --ext .js --fix || true",
    "test": "echo \"Error: no test specified\" \u0026\u0026 exit 0",
    "test:watch": "jest --watch || true",
    "audit": "npm audit --audit-level=high",
    "clean": "rm -rf dist/ release/ node_modules/.cache"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "web/**/*",
      "template/**/*",
      "item.jpg",
      "ticket.jpg"
    ],
    "outputPath": "release"
  },
  "files": [
    "src/",
    "template/",
    "item.jpg",
    "ticket.jpg"
  ],
  "keywords": [
    "minima",
    "minidapp",
    "blockchain",
    "ecommerce",
    "messaging",
    "cli"
  ],
  "author": "eurobuddha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eurobuddha/miniMerch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "png-to-ico": "^3.0.1",
    "resedit": "^3.0.2",
    "eslint": "^8.57.0"
  }
}
